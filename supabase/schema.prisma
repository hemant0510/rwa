  designationId String   @map("designation_id") @db.Uuid
  assignedAt    DateTime @default(now()) @map("assigned_at")
  assignedBy    String?  @map("assigned_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
