/// 23. Vehicle — resident vehicle registration (self-service).
model Vehicle {
  id                 String    @id @default(uuid()) @db.Uuid
  unitId             String    @map("unit_id") @db.Uuid
  societyId          String    @map("society_id") @db.Uuid
