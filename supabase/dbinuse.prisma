// prisma/dbinuse.prisma
// Eden Estate RWA Connect — Active Database Schema
// Tables currently in use (excludes Phase 2+ stubs with no active features)
// Full schema backup: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════

enum SocietyStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  OFFBOARDED
}

enum SocietyType {
  APARTMENT_COMPLEX
  BUILDER_FLOORS
  GATED_COMMUNITY_VILLAS
  INDEPENDENT_SECTOR
  PLOTTED_COLONY
}

enum SubscriptionPlan {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
  FLEX
  TRIAL
}

enum UserRole {
  RWA_ADMIN
  RESIDENT
}

enum OwnershipType {
  OWNER
  TENANT
  OTHER
}

enum AdminPermission {
  FULL_ACCESS
  READ_NOTIFY
}

enum AdminPosition {
  PRIMARY
  SUPPORTING
}

enum ResidentStatus {
  PENDING_APPROVAL
  ACTIVE_PAID
  ACTIVE_PENDING
  ACTIVE_OVERDUE
  ACTIVE_PARTIAL
  ACTIVE_EXEMPTED
  REJECTED
  MIGRATED_PENDING
  DORMANT
  DEACTIVATED
  TRANSFERRED_DEACTIVATED
  TENANT_DEPARTED
}

enum FeeStatus {
  NOT_YET_DUE
  PENDING
  OVERDUE
  PARTIAL
  PAID
  EXEMPTED
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  OTHER
}

enum ExpenseStatus {
  ACTIVE
  REVERSED
}

enum ExpenseCategory {
  MAINTENANCE
  SECURITY
  CLEANING
  STAFF_SALARY
  INFRASTRUCTURE
  UTILITIES
  EMERGENCY
  ADMINISTRATIVE
  OTHER
}

enum NotificationChannel {
  WHATSAPP
  SMS
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum AdminTermStatus {
  ACTIVE
  EXPIRED
  EXTENDED
  RESIGNED
  REMOVED
}

// Subscription system enums
enum PlanType {
  FLAT_FEE
  PER_UNIT
}

enum BillingCycle {
  MONTHLY
  ANNUAL
  TWO_YEAR
  THREE_YEAR
}

enum DiscountType {
  PERCENTAGE
  FLAT_AMOUNT
}

enum DiscountTriggerType {
  COUPON_CODE
  AUTO_TIME_LIMITED
  PLAN_SPECIFIC
  MANUAL_OVERRIDE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum SubscriptionPaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  RAZORPAY
  OTHER
}

enum InvoiceStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  OVERDUE
  WAIVED
  CANCELLED
}

enum SubscriptionChangeType {
  TRIAL_STARTED
  PLAN_SELECTED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  DISCOUNT_APPLIED
  DISCOUNT_REMOVED
  PLAN_CANCELLED
  PLAN_SUSPENDED
  PLAN_RESTORED
  PAYMENT_RECORDED
  PAYMENT_CORRECTED
  PAYMENT_REVERSED
  INVOICE_GENERATED
  INVOICE_WAIVED
  AUTO_EXPIRED
  AUTO_SUSPENDED
}

// ═══════════════════════════════════════════════════
// CORE MVP MODELS
// ═══════════════════════════════════════════════════

/// 1. Society — root tenant entity. All data is scoped to this.
model Society {
  id                    String             @id @default(uuid()) @db.Uuid
  societyId             String             @unique @map("society_id") @db.VarChar(30)
  societyCode           String             @unique @map("society_code") @db.VarChar(8)
  name                  String             @db.VarChar(200)
  registrationNo        String?            @map("registration_no") @db.VarChar(50)
  state                 String             @db.VarChar(2)
  city                  String             @db.VarChar(50)
  cityCode              String             @map("city_code") @db.VarChar(3)
  pincode               String             @db.VarChar(6)
  type                  SocietyType
  totalUnits            Int                @default(0) @map("total_units")
  joiningFee            Decimal            @default(1000) @map("joining_fee") @db.Decimal(10, 2)
  annualFee             Decimal            @default(1200) @map("annual_fee") @db.Decimal(10, 2)
  feeSessionStartMonth  Int                @default(4) @map("fee_session_start_month")
  gracePeriodDays       Int                @default(15) @map("grace_period_days")
  plan                  SubscriptionPlan   @default(BASIC)
  status                SocietyStatus      @default(ACTIVE)
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  trialEndsAt           DateTime?          @map("trial_ends_at")
  onboardingDate        DateTime           @default(now()) @map("onboarding_date")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  emailVerificationRequired Boolean      @default(true) @map("email_verification_required")

  // Relations to all child models
  users                    User[]
  units                    Unit[]
  membershipFees           MembershipFee[]
  feePayments              FeePayment[]
  expenses                 Expense[]
  notifications            Notification[]
  broadcasts               Broadcast[]
  auditLogs                AuditLog[]
  feeSessions              FeeSession[]
  notificationPreferences  NotificationPreference[]
  adminTerms               AdminTerm[]
  blacklistedNumbers       BlacklistedNumber[]
  designations             Designation[]
  governingBodyMembers     GoverningBodyMember[]
  subscriptions            SocietySubscription[]
  subscriptionPayments     SubscriptionPayment[]
  subscriptionInvoices     SubscriptionInvoice[]
  notificationLogs         NotificationLog[]

  @@map("societies")
}

/// 2. User — all platform users: Super Admin, RWA Admins, and Residents.
model User {
  id                  String           @id @default(uuid()) @db.Uuid
  societyId           String?          @map("society_id") @db.Uuid
  rwaid               String?          @unique @db.VarChar(40)
  authUserId          String?          @map("auth_user_id") @db.Uuid
  name                String           @db.VarChar(100)
  mobile              String?          @db.VarChar(15)
  email               String           @db.VarChar(100)
  photoUrl            String?          @map("photo_url") @db.VarChar(500)
  idProofUrl          String?          @map("id_proof_url") @db.VarChar(500)
  ownershipProofUrl   String?          @map("ownership_proof_url") @db.VarChar(500)
  role                UserRole
  ownershipType       OwnershipType?   @map("ownership_type")
  otherOwnershipDetail String?         @map("other_ownership_detail") @db.VarChar(100)
  status              ResidentStatus   @default(PENDING_APPROVAL)
  adminPermission     AdminPermission? @map("admin_permission")
  isEmailVerified     Boolean          @default(false) @map("is_email_verified")
  consentWhatsapp     Boolean          @default(false) @map("consent_whatsapp")
  consentWhatsappAt   DateTime?        @map("consent_whatsapp_at")
  pinHash             String?          @map("pin_hash") @db.VarChar(100)
  pinFailedAttempts   Int              @default(0) @map("pin_failed_attempts")
  pinLockedUntil      DateTime?        @map("pin_locked_until")
  joiningFeePaid      Boolean          @default(false) @map("joining_fee_paid")
  registeredAt        DateTime         @default(now()) @map("registered_at")
  approvedAt          DateTime?        @map("approved_at")
  approvedById        String?          @map("approved_by") @db.Uuid
  rejectedAt          DateTime?        @map("rejected_at")
  rejectedById        String?          @map("rejected_by") @db.Uuid
  rejectionReason     String?          @map("rejection_reason")
  activatedAt         DateTime?        @map("activated_at")
  deactivatedAt       DateTime?        @map("deactivated_at")
  deactivationReason  String?          @map("deactivation_reason")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  // Self-relations
  society             Society?         @relation(fields: [societyId], references: [id])
  approvedBy          User?            @relation("UserApprovedBy", fields: [approvedById], references: [id])
  rejectedBy          User?            @relation("UserRejectedBy", fields: [rejectedById], references: [id])
  approvedUsers       User[]           @relation("UserApprovedBy")
  rejectedUsers       User[]           @relation("UserRejectedBy")

  // Relations to child models
  userUnits              UserUnit[]
  membershipFees         MembershipFee[]
  feePaymentsAsUser      FeePayment[]          @relation("FeePaymentUser")
  feePaymentsRecorded    FeePayment[]          @relation("FeePaymentRecordedBy")
  feesExemptedByUser     MembershipFee[]       @relation("FeeExemptedBy")
  expensesLogged         Expense[]             @relation("ExpenseLoggedBy")
  expensesReversed       Expense[]             @relation("ExpenseReversedBy")
  notifications          Notification[]
  broadcastsSent         Broadcast[]
  auditLogs              AuditLog[]
  notificationPreferences  NotificationPreference[]
  ownedUnits             Unit[]                @relation("UnitPrimaryOwner")
  tenantUnits            Unit[]                @relation("UnitCurrentTenant")
  adminTerms             AdminTerm[]
  adminTermsActivated    AdminTerm[]           @relation("AdminTermActivatedBy")
  adminTermsDeactivated  AdminTerm[]           @relation("AdminTermDeactivatedBy")
  blacklistedNumbers     BlacklistedNumber[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens    PasswordResetToken[]
  governingBodyMembership GoverningBodyMember?  @relation("GoverningBodyMember")
  governingBodyAssignments GoverningBodyMember[] @relation("GoverningBodyAssigner")

  @@unique([societyId, email])
  @@map("users")
}

/// Email verification tokens for user email confirmation.
model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

/// Password reset tokens for forgot password flow.
model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

/// 2b. SuperAdmin — platform super administrators (separate from society users).
model SuperAdmin {
  id         String   @id @default(uuid()) @db.Uuid
  authUserId String   @unique @map("auth_user_id") @db.Uuid
  email      String   @unique @db.VarChar(100)
  name       String   @db.VarChar(100)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("super_admins")
}

/// 3. Unit — physical property units (houses, flats, villas, plots).
model Unit {
  id              String    @id @default(uuid()) @db.Uuid
  societyId       String    @map("society_id") @db.Uuid
  displayLabel    String    @map("display_label") @db.VarChar(50)
  towerBlock      String?   @map("tower_block") @db.VarChar(20)
  floorNo         String?   @map("floor_no") @db.VarChar(10)
  flatNo          String?   @map("flat_no") @db.VarChar(20)
  houseNo         String?   @map("house_no") @db.VarChar(20)
  floorLevel      String?   @map("floor_level") @db.VarChar(10)
  villaNo         String?   @map("villa_no") @db.VarChar(20)
  streetPhase     String?   @map("street_phase") @db.VarChar(30)
  sectorBlock     String?   @map("sector_block") @db.VarChar(20)
  streetGali      String?   @map("street_gali") @db.VarChar(20)
  plotNo          String?   @map("plot_no") @db.VarChar(20)
  laneNo          String?   @map("lane_no") @db.VarChar(20)
  phase           String?   @db.VarChar(20)
  unitType        String?   @map("unit_type") @db.VarChar(20) // Flat/Floor/Villa/Shop
  areaInSqft      Decimal?  @map("area_in_sqft") @db.Decimal(10, 2) // Phase 2: tiered fee calc
  parkingSlotsAllotted Int? @map("parking_slots_allotted") // Phase 2: slot approval
  evChargingSlot  Boolean?  @map("ev_charging_slot") // Phase 2: EV management
  unitStatus      String    @default("VACANT") @map("unit_status") @db.VarChar(20) // VACANT / OCCUPIED
  primaryOwnerId  String?   @map("primary_owner_id") @db.Uuid
  currentTenantId String?   @map("current_tenant_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  society         Society   @relation(fields: [societyId], references: [id])
  primaryOwner    User?     @relation("UnitPrimaryOwner", fields: [primaryOwnerId], references: [id])
  currentTenant   User?     @relation("UnitCurrentTenant", fields: [currentTenantId], references: [id])
  userUnits       UserUnit[]
  membershipFees  MembershipFee[]

  @@map("units")
}

/// 4. UserUnit — join table linking residents to units.
model UserUnit {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  unitId       String    @map("unit_id") @db.Uuid
  isPrimary    Boolean   @default(true) @map("is_primary")
  relationship String    @default("OWNER") @db.VarChar(20)
  linkedAt     DateTime  @default(now()) @map("linked_at")
  unlinkedAt   DateTime? @map("unlinked_at")

  user         User      @relation(fields: [userId], references: [id])
  unit         Unit      @relation(fields: [unitId], references: [id])

  @@unique([userId, unitId])
  @@map("user_units")
}

/// 5. MembershipFee — session-wise fee records per user.
model MembershipFee {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @map("user_id") @db.Uuid
  unitId            String?    @map("unit_id") @db.Uuid
  societyId         String     @map("society_id") @db.Uuid
  sessionYear       String     @map("session_year") @db.VarChar(7)
  sessionStart      DateTime   @map("session_start") @db.Date
  sessionEnd        DateTime   @map("session_end") @db.Date
  amountDue         Decimal    @map("amount_due") @db.Decimal(10, 2)
  amountPaid        Decimal    @default(0) @map("amount_paid") @db.Decimal(10, 2)
  status            FeeStatus  @default(NOT_YET_DUE)
  gracePeriodEnd    DateTime?  @map("grace_period_end") @db.Date
  isProrata         Boolean    @default(false) @map("is_prorata")
  prorataMonths     Int?       @map("prorata_months")
  joiningFeeIncluded Boolean   @default(false) @map("joining_fee_included")
  exemptionReason   String?    @map("exemption_reason")
  exemptedBy        String?    @map("exempted_by") @db.Uuid
  exemptedAt        DateTime?  @map("exempted_at")
  isPreMigration    Boolean    @default(false) @map("is_pre_migration")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user              User       @relation(fields: [userId], references: [id])
  unit              Unit?      @relation(fields: [unitId], references: [id])
  society           Society    @relation(fields: [societyId], references: [id])
  exemptedByUser    User?      @relation("FeeExemptedBy", fields: [exemptedBy], references: [id])
  feePayments       FeePayment[]

  @@unique([userId, sessionYear])
  @@map("membership_fees")
}

/// 6. FeePayment — individual payment entries against a fee record.
model FeePayment {
  id                   String       @id @default(uuid()) @db.Uuid
  feeId                String       @map("fee_id") @db.Uuid
  userId               String       @map("user_id") @db.Uuid
  societyId            String       @map("society_id") @db.Uuid
  amount               Decimal      @db.Decimal(10, 2)
  paymentMode          PaymentMode  @map("payment_mode")
  referenceNo          String?      @map("reference_no") @db.VarChar(50)
  receiptNo            String       @unique @map("receipt_no") @db.VarChar(50)
  receiptUrl           String?      @map("receipt_url") @db.VarChar(500)
  paymentDate          DateTime     @map("payment_date") @db.Date
  notes                String?
  recordedBy           String       @map("recorded_by") @db.Uuid
  isReversal           Boolean      @default(false) @map("is_reversal")
  reversalOf           String?      @map("reversal_of") @db.Uuid
  reversalReason       String?      @map("reversal_reason")
  isReversed           Boolean      @default(false) @map("is_reversed")
  correctionWindowEnds DateTime?    @map("correction_window_ends")
  createdAt            DateTime     @default(now()) @map("created_at")

  fee                  MembershipFee @relation(fields: [feeId], references: [id])
  user                 User          @relation("FeePaymentUser", fields: [userId], references: [id])
  society              Society       @relation(fields: [societyId], references: [id])
  recorder             User          @relation("FeePaymentRecordedBy", fields: [recordedBy], references: [id])
  originalPayment      FeePayment?   @relation("PaymentReversal", fields: [reversalOf], references: [id])
  reversals            FeePayment[]  @relation("PaymentReversal")

  @@map("fee_payments")
}

/// 7. Expense — society expense ledger.
model Expense {
  id                   String          @id @default(uuid()) @db.Uuid
  societyId            String          @map("society_id") @db.Uuid
  date                 DateTime        @db.Date
  amount               Decimal         @db.Decimal(10, 2)
  category             ExpenseCategory
  description          String
  receiptUrl           String?         @map("receipt_url") @db.VarChar(500)
  loggedBy             String          @map("logged_by") @db.Uuid
  status               ExpenseStatus   @default(ACTIVE)
  reversalNote         String?         @map("reversal_note")
  reversedBy           String?         @map("reversed_by") @db.Uuid
  reversedAt           DateTime?       @map("reversed_at")
  correctionWindowEnds DateTime?       @map("correction_window_ends")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  society              Society         @relation(fields: [societyId], references: [id])
  logger               User            @relation("ExpenseLoggedBy", fields: [loggedBy], references: [id])
  reverser             User?           @relation("ExpenseReversedBy", fields: [reversedBy], references: [id])

  @@map("expenses")
}

/// 8. Notification — WhatsApp/SMS delivery tracking.
model Notification {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  societyId       String?            @map("society_id") @db.Uuid
  type            String             @db.VarChar(50)
  channel         NotificationChannel
  templateName    String?            @map("template_name") @db.VarChar(100)
  contentVars     Json?              @map("content_vars")
  contentPreview  String?            @map("content_preview")
  status          NotificationStatus @default(QUEUED)
  sentAt          DateTime?          @map("sent_at")
  deliveredAt     DateTime?          @map("delivered_at")
  readAt          DateTime?          @map("read_at")
  failedReason    String?            @map("failed_reason")
  retryCount      Int                @default(0) @map("retry_count")
  broadcastId     String?            @map("broadcast_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")

  user            User               @relation(fields: [userId], references: [id])
  society         Society?           @relation(fields: [societyId], references: [id])

  @@map("notifications")
}

/// 9. Broadcast — manual broadcast records.
model Broadcast {
  id              String   @id @default(uuid()) @db.Uuid
  societyId       String   @map("society_id") @db.Uuid
  sentBy          String   @map("sent_by") @db.Uuid
  message         String
  recipientFilter String   @map("recipient_filter") @db.VarChar(30)
  recipientCount  Int      @map("recipient_count")
  deliveredCount  Int      @default(0) @map("delivered_count")
  failedCount     Int      @default(0) @map("failed_count")
  sentAt          DateTime @default(now()) @map("sent_at")
  createdAt       DateTime @default(now()) @map("created_at")

  society         Society  @relation(fields: [societyId], references: [id])
  sender          User     @relation(fields: [sentBy], references: [id])

  @@map("broadcasts")
}

/// 10. AuditLog — immutable operation log (INSERT only).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  societyId  String?  @map("society_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  actionType String   @map("action_type") @db.VarChar(20)
  entityType String   @map("entity_type") @db.VarChar(30)
  entityId   String   @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  society    Society? @relation(fields: [societyId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

/// 13. FeeSession — financial session configuration per society per year.
model FeeSession {
  id              String   @id @default(uuid()) @db.Uuid
  societyId       String   @map("society_id") @db.Uuid
  sessionYear     String   @map("session_year") @db.VarChar(7)
  annualFee       Decimal  @map("annual_fee") @db.Decimal(10, 2)
  joiningFee      Decimal  @map("joining_fee") @db.Decimal(10, 2)
  sessionStart    DateTime @map("session_start") @db.Date
  sessionEnd      DateTime @map("session_end") @db.Date
  gracePeriodEnd  DateTime @map("grace_period_end") @db.Date
  status          String   @default("UPCOMING") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  society         Society  @relation(fields: [societyId], references: [id])

  @@unique([societyId, sessionYear])
  @@map("fee_sessions")
}

/// 14. NotificationPreference — resident opt-in/opt-out for optional notifications.
model NotificationPreference {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  societyId         String   @map("society_id") @db.Uuid
  feeReminder       Boolean  @default(true) @map("fee_reminder")
  feeOverdueAlert   Boolean  @default(true) @map("fee_overdue_alert")
  societyBroadcasts Boolean  @default(true) @map("society_broadcasts")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user              User     @relation(fields: [userId], references: [id])
  society           Society  @relation(fields: [societyId], references: [id])

  @@unique([userId, societyId])
  @@map("notification_preferences")
}

/// 15. AdminTerm — admin election lifecycle.
model AdminTerm {
  id                  String          @id @default(uuid()) @db.Uuid
  userId              String          @map("user_id") @db.Uuid
  societyId           String          @map("society_id") @db.Uuid
  position            AdminPosition
  permission          AdminPermission
  termStart           DateTime        @map("term_start")
  termEnd             DateTime        @map("term_end")
  status              AdminTermStatus @default(ACTIVE)
  extensionCount      Int             @default(0) @map("extension_count")
  activatedBy         String?         @map("activated_by") @db.Uuid
  deactivatedBy       String?         @map("deactivated_by") @db.Uuid
  deactivationReason  String?         @map("deactivation_reason")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  user                User            @relation(fields: [userId], references: [id])
  society             Society         @relation(fields: [societyId], references: [id])
  activator           User?           @relation("AdminTermActivatedBy", fields: [activatedBy], references: [id])
  deactivator         User?           @relation("AdminTermDeactivatedBy", fields: [deactivatedBy], references: [id])

  @@map("admin_terms")
}

/// 22. BlacklistedNumber — blocked mobile numbers per society.
model BlacklistedNumber {
  id            String   @id @default(uuid()) @db.Uuid
  societyId     String   @map("society_id") @db.Uuid
  mobile        String   @db.VarChar(15)
  reason        String
  blacklistedBy String   @map("blacklisted_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  society       Society  @relation(fields: [societyId], references: [id])
  blacklister   User     @relation(fields: [blacklistedBy], references: [id])

  @@unique([societyId, mobile])
  @@map("blacklisted_numbers")
}

/// 24. Designation — governing body designations per society.
model Designation {
  id        String   @id @default(uuid()) @db.Uuid
  societyId String   @map("society_id") @db.Uuid
  name      String   @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  society Society               @relation(fields: [societyId], references: [id])
  members GoverningBodyMember[]

  @@unique([societyId, name])
  @@map("designations")
}

/// 25. GoverningBodyMember — assigns a resident to a designation (informational).
model GoverningBodyMember {
  id            String   @id @default(uuid()) @db.Uuid
  societyId     String   @map("society_id") @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  designationId String   @map("designation_id") @db.Uuid
  assignedAt    DateTime @default(now()) @map("assigned_at")
  assignedBy    String?  @map("assigned_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  society     Society     @relation(fields: [societyId], references: [id])
  user        User        @relation("GoverningBodyMember", fields: [userId], references: [id])
  designation Designation @relation(fields: [designationId], references: [id])
  assigner    User?       @relation("GoverningBodyAssigner", fields: [assignedBy], references: [id])

  @@map("governing_body_members")
}

// ═══════════════════════════════════════════════════
// SUBSCRIPTION SYSTEM MODELS
// ═══════════════════════════════════════════════════

/// 26. PlatformPlan — dynamic subscription plan definitions created by Super Admin.
model PlatformPlan {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(100)
  slug             String    @unique @db.VarChar(50)
  description      String?
  planType         PlanType  @map("plan_type")
  residentLimit    Int?      @map("resident_limit")                     // null = unlimited; FLAT_FEE only
  pricePerUnit     Decimal?  @map("price_per_unit") @db.Decimal(10, 2) // PER_UNIT plans only
  featuresJson     Json      @map("features_json")                      // { whatsapp, elections, ai_insights, ... }
  isActive         Boolean   @default(true) @map("is_active")
  isPublic         Boolean   @default(true) @map("is_public")           // false = hidden from onboarding
  displayOrder     Int       @default(0) @map("display_order")
  badgeText        String?   @map("badge_text") @db.VarChar(50)         // "Most Popular", "Best Value"
  trialAccessLevel Boolean   @default(false) @map("trial_access_level") // if true, trial societies get this plan's features
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  billingOptions   PlanBillingOption[]
  subscriptions    SocietySubscription[]
  fromHistory      SocietySubscriptionHistory[] @relation("HistoryFromPlan")
  toHistory        SocietySubscriptionHistory[] @relation("HistoryToPlan")

  @@map("platform_plans")
}

/// 27. PlanBillingOption — billing cycle options and prices per plan.
model PlanBillingOption {
  id           String       @id @default(uuid()) @db.Uuid
  planId       String       @map("plan_id") @db.Uuid
  billingCycle BillingCycle @map("billing_cycle")
  price        Decimal      @db.Decimal(10, 2)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  plan          PlatformPlan                 @relation(fields: [planId], references: [id])
  subscriptions SocietySubscription[]
  fromHistory   SocietySubscriptionHistory[] @relation("HistoryFromBillingOption")
  toHistory     SocietySubscriptionHistory[] @relation("HistoryToBillingOption")

  @@unique([planId, billingCycle])
  @@map("plan_billing_options")
}

/// 28. PlanDiscount — discount configurations: coupon codes, time-limited, plan-specific, manual override.
model PlanDiscount {
  id                  String              @id @default(uuid()) @db.Uuid
  name                String              @db.VarChar(150)
  description         String?
  discountType        DiscountType        @map("discount_type")
  discountValue       Decimal             @map("discount_value") @db.Decimal(10, 2) // 40 = 40%, 500 = ₹500 off
  appliesToAll        Boolean             @default(false) @map("applies_to_all")
  applicablePlanIds   String[]            @map("applicable_plan_ids")               // UUIDs of specific plans; empty if appliesToAll
  triggerType         DiscountTriggerType @map("trigger_type")
  couponCode          String?             @unique @map("coupon_code") @db.VarChar(30)
  startsAt            DateTime?           @map("starts_at")
  endsAt              DateTime?           @map("ends_at")
  maxUsageCount       Int?                @map("max_usage_count")                   // null = unlimited
  usageCount          Int                 @default(0) @map("usage_count")
  allowedCycles       BillingCycle[]      @map("allowed_cycles")                   // empty = all cycles allowed
  isActive            Boolean             @default(true) @map("is_active")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  subscriptions SocietySubscription[]

  @@map("plan_discounts")
}

/// 29. SocietySubscription — current and historical subscription records per society.
model SocietySubscription {
  id                 String             @id @default(uuid()) @db.Uuid
  societyId          String             @map("society_id") @db.Uuid
  planId             String?            @map("plan_id") @db.Uuid            // null during trial (before plan selected)
  billingOptionId    String?            @map("billing_option_id") @db.Uuid
  status             SubscriptionStatus @default(TRIAL)
  trialStartsAt      DateTime?          @map("trial_starts_at")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  discountId         String?            @map("discount_id") @db.Uuid
  customDiscountPct  Decimal?           @map("custom_discount_pct") @db.Decimal(5, 2)  // for MANUAL_OVERRIDE
  finalPrice         Decimal?           @map("final_price") @db.Decimal(10, 2)          // effective price after discount
  unitCountSnapshot  Int?               @map("unit_count_snapshot")                     // snapshot for PER_UNIT billing
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  society       Society            @relation(fields: [societyId], references: [id])
  plan          PlatformPlan?      @relation(fields: [planId], references: [id])
  billingOption PlanBillingOption? @relation(fields: [billingOptionId], references: [id])
  discount      PlanDiscount?      @relation(fields: [discountId], references: [id])
  history       SocietySubscriptionHistory[]
  payments      SubscriptionPayment[]
  invoices      SubscriptionInvoice[]

  @@map("society_subscriptions")
}

/// 30. SocietySubscriptionHistory — immutable audit trail of all subscription changes.
model SocietySubscriptionHistory {
  id                  String                 @id @default(uuid()) @db.Uuid
  subscriptionId      String                 @map("subscription_id") @db.Uuid
  societyId           String                 @map("society_id") @db.Uuid
  changeType          SubscriptionChangeType @map("change_type")
  fromPlanId          String?                @map("from_plan_id") @db.Uuid
  toPlanId            String?                @map("to_plan_id") @db.Uuid
  fromBillingOptionId String?                @map("from_billing_option_id") @db.Uuid
  toBillingOptionId   String?                @map("to_billing_option_id") @db.Uuid
  prorataCredit       Decimal?               @map("prorata_credit") @db.Decimal(10, 2)
  prorataCharge       Decimal?               @map("prorata_charge") @db.Decimal(10, 2)
  netAmount           Decimal?               @map("net_amount") @db.Decimal(10, 2)
  performedBy         String                 @map("performed_by") @db.VarChar(100) // SA user ID or "SYSTEM"
  notes               String?
  createdAt           DateTime               @default(now()) @map("created_at")

  subscription      SocietySubscription @relation(fields: [subscriptionId], references: [id])
  fromPlan          PlatformPlan?       @relation("HistoryFromPlan", fields: [fromPlanId], references: [id])
  toPlan            PlatformPlan?       @relation("HistoryToPlan", fields: [toPlanId], references: [id])
  fromBillingOption PlanBillingOption?  @relation("HistoryFromBillingOption", fields: [fromBillingOptionId], references: [id])
  toBillingOption   PlanBillingOption?  @relation("HistoryToBillingOption", fields: [toBillingOptionId], references: [id])

  @@map("society_subscription_history")
}

/// 31. SubscriptionPayment — records subscription payment entries per society.
model SubscriptionPayment {
  id                   String                  @id @default(uuid()) @db.Uuid
  societyId            String                  @map("society_id") @db.Uuid
  subscriptionId       String                  @map("subscription_id") @db.Uuid
  invoiceId            String?                 @map("invoice_id") @db.Uuid
  amount               Decimal                 @db.Decimal(12, 2)
  paymentMode          SubscriptionPaymentMode @map("payment_mode")
  referenceNo          String?                 @map("reference_no") @db.VarChar(50)
  invoiceNo            String                  @unique @map("invoice_no") @db.VarChar(50)
  invoiceUrl           String?                 @map("invoice_url") @db.VarChar(500)
  paymentDate          DateTime                @map("payment_date") @db.Date
  notes                String?
  recordedBy           String                  @map("recorded_by") @db.Uuid
  isReversal           Boolean                 @default(false) @map("is_reversal")
  reversalOf           String?                 @map("reversal_of") @db.Uuid
  reversalReason       String?                 @map("reversal_reason")
  isReversed           Boolean                 @default(false) @map("is_reversed")
  correctionWindowEnds DateTime?              @map("correction_window_ends")
  createdAt            DateTime                @default(now()) @map("created_at")

  society         Society              @relation(fields: [societyId], references: [id])
  subscription    SocietySubscription  @relation(fields: [subscriptionId], references: [id])
  invoice         SubscriptionInvoice? @relation(fields: [invoiceId], references: [id])
  reversalPayment SubscriptionPayment? @relation("SubscriptionPaymentReversal", fields: [reversalOf], references: [id])
  reversedBy      SubscriptionPayment[] @relation("SubscriptionPaymentReversal")

  @@map("subscription_payments")
}

/// 32. SubscriptionInvoice — tracks generated invoices for subscription renewals.
model SubscriptionInvoice {
  id             String                  @id @default(uuid()) @db.Uuid
  societyId      String                  @map("society_id") @db.Uuid
  subscriptionId String                  @map("subscription_id") @db.Uuid
  invoiceNo      String                  @unique @map("invoice_no") @db.VarChar(50)
  periodStart    DateTime                @map("period_start")
  periodEnd      DateTime                @map("period_end")
  planName       String                  @map("plan_name")
  billingCycle   BillingCycle            @map("billing_cycle")
  baseAmount     Decimal                 @map("base_amount") @db.Decimal(12, 2)
  discountAmount Decimal                 @default(0) @map("discount_amount") @db.Decimal(12, 2)
  finalAmount    Decimal                 @map("final_amount") @db.Decimal(12, 2)
  status         InvoiceStatus           @default(UNPAID)
  dueDate        DateTime                @map("due_date")
  paidAt         DateTime?               @map("paid_at")
  paidVia        SubscriptionPaymentMode? @map("paid_via")
  notes          String?
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  society      Society               @relation(fields: [societyId], references: [id])
  subscription SocietySubscription   @relation(fields: [subscriptionId], references: [id])
  payments     SubscriptionPayment[]

  @@map("subscription_invoices")
}

/// 33. NotificationLog — deduplicates automated reminders by period and template.
model NotificationLog {
  id          String   @id @default(uuid()) @db.Uuid
  societyId   String   @map("society_id") @db.Uuid
  templateKey String   @map("template_key")
  periodKey   String   @map("period_key")
  sentAt      DateTime @default(now()) @map("sent_at")
  channel     String   @default("email")

  society Society @relation(fields: [societyId], references: [id])

  @@unique([societyId, templateKey, periodKey])
  @@map("notification_logs")
}
