# ──────────────────────────────────────────────
# RWA Connect — Environment Variables
# ──────────────────────────────────────────────
#
# ENVIRONMENTS:
#   Each environment (dev, staging, prod) should have its own
#   Supabase project and set of credentials.
#
#   Local dev  → copy this file to .env.local and fill in values
#   Azure      → set via infra/env-vars-per-environment.sh
#   GitHub CI  → set via GitHub Environment secrets (see infra/setup-azure.sh)
#
# ──────────────────────────────────────────────

# ──────────────────────────────────────────────
# SUPABASE  (Settings → API in Supabase Dashboard)
# ──────────────────────────────────────────────

# Project URL  →  Settings → API → "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# anon / public key  →  Settings → API → Project API keys → "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# service_role / secret key  →  Settings → API → Project API keys → "service_role secret"
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ──────────────────────────────────────────────
# DATABASE  (Settings → Database in Supabase Dashboard)
# ──────────────────────────────────────────────

# Connection string (Transaction / Pooler)  →  Settings → Database → Connection string → "Transaction" tab
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Connection string (Session / Direct)  →  Settings → Database → Connection string → "Session" tab
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────

# Local: http://localhost:3000
# Dev:   https://dev.yourdomain.com
# Staging: https://staging.yourdomain.com
# Prod:  https://app.yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Trial configuration
TRIAL_PERIOD_DAYS=14
MAX_TRIAL_RESIDENTS=50

# ──────────────────────────────────────────────
# EMAIL (Gmail SMTP)  —  optional for dev (verification auto-disabled if missing)
# Setup: create a Gmail account → enable 2FA → generate App Password
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-app@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="RWA Connect <your-app@gmail.com>"

# ──────────────────────────────────────────────
# WHATSAPP (WATI)  —  optional, skip for now
# ──────────────────────────────────────────────
WATI_API_URL=https://live-mt-server.wati.io
WATI_API_KEY=

# ──────────────────────────────────────────────
# SENTRY  —  optional, skip for now
# ──────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
